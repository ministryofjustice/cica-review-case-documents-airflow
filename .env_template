# Values here will override the Settings in config.py when running locally

# OpenSearch config
OPENSEARCH_CHUNK_INDEX_NAME=page_chunks
OPENSEARCH_PAGE_METADATA_INDEX_NAME=page_metadata

# Continue to use this when port forwarding to dev and uat.
OPENSEARCH_PROXY_URL=http://localhost:9200

# Global Document Chunking Configuration
# [linear-sentence-splitter, layout, textractor-word-stream]
DOCUMENT_CHUNKING_STRATEGY=textractor-word-stream

# Layout Chunking strategy config
LAYOUT_CHUNKING_MAXIMUM_CHUNK_SIZE=60
LAYOUT_CHUNKING_Y_TOLERANCE_RATIO=0.5
LAYOUT_CHUNKING_MAX_VERTICAL_GAP=0.5
LAYOUT_CHUNKING_LINE_CHUNK_CHAR_LIMIT=300

# -- Line-by-Line Sentence Chunker strategy Configuration --
# Word-based limits (not character-based)
SENTENCE_CHUNKER_MIN_WORDS=80
SENTENCE_CHUNKER_MAX_WORDS=120
# Vertical gap threshold (relative to page height, 0.0-1.0)
SENTENCE_CHUNKER_MAX_VERTICAL_GAP_RATIO=0.05

# LOG_LEVEL=INFO

# Textract runs in MOD PLATFORM sandbox and is not yet wired up for CICA AWS resources, 
# so we point it to the redacted document in the MOD PLATFORM sandbox bucket for now
# TODO fix spelling mistake in bucket name, create new remote bucket for 
# textract output that is separate from the source document bucket, and update this config to point to the new bucket
USE_MOD_PLATFORM_MODE=true
AWS_LOCAL_DEV_TEXTRACT_S3_ROOT_BUCKET=mod-platform-sandbox-kta-documents-bucket

AWS_MOD_PLATFORM_ACCESS_KEY_ID=<mod_platform_access_key_id>
AWS_MOD_PLATFORM_SECRET_ACCESS_KEY=<mod_platform_secret_access_key>
AWS_MOD_PLATFORM_SESSION_TOKEN=<mod_platform_session_token>

# -- Local Development Mode --
# Set LOCAL_DEVELOPMENT_MODE to true to enable localstack configuration
# Defaults to false if not set
# Set to FALSE when using  CICA AWS resources for development, true when using localstack for local development
LOCAL_DEVELOPMENT_MODE=true


AWS_CICA_S3_SOURCE_DOCUMENT_CASE_PREFIX=26-711111
AWS_CICA_S3_SOURCE_DOCUMENT_FILENAME=Case1_TC19_50_pages_brain_injury.pdf

# LOCAL STACK CONFIGURATION FOR LOCAL DEVELOPMENT
AWS_CICA_S3_SOURCE_DOCUMENT_ROOT_BUCKET=local-kta-documents-bucket
AWS_CICA_S3_PAGE_BUCKET_URI=http://localhost:4566
AWS_CICA_S3_PAGE_BUCKET=document-page-bucket
AWS_CICA_AWS_ACCESS_KEY_ID=test
AWS_CICA_AWS_SECRET_ACCESS_KEY=test
AWS_CICA_AWS_SESSION_TOKEN=test


# DEV CONFIGURATION FOR CICA AWS RESOURCES

# CICA S3 bucket for KTA documents
# TODO add readme instructions for port forwarding to allow local development against real AWS resources, 
# and dev and uat environments
# AWS_CICA_S3_SOURCE_DOCUMENT_ROOT_BUCKET=dev-documentsearch-kta-bucket
# AWS_CICA_S3_PAGE_BUCKET_URI=s3://dev-documentsearch-kta-bucket
# AWS_CICA_S3_PAGE_BUCKET=dev-documentsearch-kta-bucket
# AWS_CICA_AWS_ACCESS_KEY_ID=<cica_dev_access_key_id>
# AWS_CICA_AWS_SECRET_ACCESS_KEY=<cica_dev_secret_access_key>
# AWS_CICA_AWS_SESSION_TOKEN=<cica_dev_session_token>

# UAT CONFIGURATION FOR CICA AWS RESOURCES

# AWS_CICA_S3_SOURCE_DOCUMENT_ROOT_BUCKET=uat-documentsearch-kta-bucket
# AWS_CICA_S3_PAGE_BUCKET_URI=s3://uat-documentsearch-kta-bucket
# AWS_CICA_S3_PAGE_BUCKET=uat-documentsearch-kta-bucket
# AWS_CICA_AWS_ACCESS_KEY_ID=<cica_uat_access_key_id>
# AWS_CICA_AWS_SECRET_ACCESS_KEY=<cica_uat_secret_access_key>
# AWS_CICA_AWS_SESSION_TOKEN=<cica_uat_session_token>


DEBUG_PAGE_NUMBERS=[3]

# Mod platform credentials
AWS_REGION=eu-west-2


