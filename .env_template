# VALUES HERE WILL OVERRIDE THE SETTINGS IN CONFIG.PY WHEN RUNNING LOCALLY
# ALL KEYS SHOULD BE UPPERCASE WITH UNDERSCORES.
# NO QUOTES AROUND VALUES.

# OpenSearch configuration
# A single proxy/base URL for the OpenSearch cluster. This is a required field.
OPENSEARCH_PROXY_URL=http://localhost:9200
OPENSEARCH_CHUNK_INDEX_NAME=page_chunks
OPENSEARCH_PAGE_METADATA_INDEX_NAME=page_metadata

# -- Local Development Mode --
# Set LOCAL_DEVELOPMENT_MODE to true to enable localstack configuration
# Defaults to false if not set
LOCAL_DEVELOPMENT_MODE=true

# Local development mode flag (can be set via environment variable)
# This will switch the S3 URI to point to a mod platform bucket for AWS Textract integration.
# This will be removed when AWS Textract has been configured to use CICA AWS S3 buckets directly.
USE_MOD_PLATFORM_MODE=true
# Textract runs in MOD PLATFROM sandbox and is not yet wired up for CICA AWS resources, 
# so we point it to the redacted document in the MOD PLATFORM sandbox bucket for now
AWS_LOCAL_DEV_TEXTRACT_S3_ROOT_BUCKET=mod-platfform-sandbox-kta-documents-bucket

# Global AWS configuration
AWS_REGION=eu-west-2

# MOD PLATFORM AWS credentials for local development mode
AWS_MOD_PLATFORM_ACCESS_KEY_ID=AWS_MOD_PLATFORM_ACCESS_KEY_ID
AWS_MOD_PLATFORM_SECRET_ACCESS_KEY=AWS_MOD_PLATFORM_SECRET_ACCESS_KEY
AWS_MOD_PLATFORM_SESSION_TOKEN=AWS_MOD_PLATFORM_SESSION_TOKEN

# Page processing configuration
# S3 bucket for source documents, NOTE for local development we use both the localstack bucket
# and currently the mod-platform sandbox bucket
AWS_CICA_S3_SOURCE_DOCUMENT_ROOT_BUCKET=local-kta-documents-bucket
AWS_CICA_S3_SOURCE_DOCUMENT_CASE_PREFIX=26-711111
AWS_CICA_S3_SOURCE_DOCUMENT_FILENAME=Case1_TC19_50_pages_brain_injury.pdf

 # S3 localstack bucket for source documents
AWS_CICA_S3_PAGE_BUCKET_URI=http://localhost:4566
AWS_CICA_S3_PAGE_BUCKET=document-page-bucket
AWS_CICA_AWS_ACCESS_KEY_ID=test
AWS_CICA_AWS_SECRET_ACCESS_KEY=test
AWS_CICA_AWS_SESSION_TOKEN=test

# Global Document Chunking Configuration
# [linear-sentence-splitter, layout]
DOCUMENT_CHUNKING_STRATEGY=linear-sentence-splitter


# Layout Chunking strategy config
LAYOUT_CHUNKING_MAXIMUM_CHUNK_SIZE=80
LAYOUT_CHUNKING_Y_TOLERANCE_RATIO=0.5
LAYOUT_CHUNKING_MAX_VERTICAL_GAP=0.5
LAYOUT_CHUNKING_LINE_CHUNK_CHAR_LIMIT=300

# -- Line-by-Line Sentence Chunker strategy Configuration --
# NOTE: The defaults in config.py may differ from these values.
# These .env values are for local development and experimentation.
# The ideal production settings are still under review.
# Word-based limits (not character-based)
SENTENCE_CHUNKER_MIN_WORDS=80
SENTENCE_CHUNKER_MAX_WORDS=100
# Vertical gap threshold (relative to page height, 0.0-1.0)
SENTENCE_CHUNKER_MAX_VERTICAL_GAP_RATIO=0.05

# Configuration for logging as desired
# Options include DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO
# Used for extra logging on specific pages - set to comma separated list of page numbers to enable
# Defaults to Page 1 if not set, can be set to empty to disable
DEBUG_PAGE_NUMBERS=[3]




